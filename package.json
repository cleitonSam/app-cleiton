{
  "name": "linha",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "Linha — copiloto de rotina. PWA com login, aprovação de acesso e sincronismo entre aparelhos.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -n api,web -c blue,magenta \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "node --watch --env-file=.env server/index.js",
    "dev:web": "vite",
    "build": "vite build",
    "start": "node server/index.js",
    "preview": "npm run build && node --env-file=.env server/index.js",
    "db:local": "docker compose -f docker-compose.dev.yml up -d",
    "db:local:down": "docker compose -f docker-compose.dev.yml down -v"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/static": "^8.0.4",
    "fastify": "^5.2.1",
    "pg": "^8.13.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "pino-pretty": "^13.0.0",
    "vite": "^5.4.11"
  }
}
